<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ML Daily Brief — {{ date }}</title>
  <link rel="stylesheet" href="./style.css">
  <script>
    (function() {
      var t = localStorage.getItem('theme');
      if (t === 'light') document.documentElement.style.background = '#e8ede8';
    })();
  </script>
</head>
<body>
  <div class="page">
    <header>
      <a class="archive-link" href="{{ base_url }}/index.html">← All Briefs</a>
      <button class="theme-toggle" aria-label="Toggle light/dark mode" title="Toggle light/dark mode"></button>
      <h1>🧠 ML Daily Brief</h1>
      <p class="date">{{ date }}</p>
    </header>

    <main class="brief-content">
      {{ content | safe }}
    </main>

    <footer>
      <p>Generated by <a href="./index.html">Daily Briefs</a></p>
    </footer>
  </div>
  <script>
    (function() {
      var btn = document.querySelector('.theme-toggle');
      var body = document.body;
      function setTheme(theme) {
        if (theme === 'light') {
          body.classList.add('light');
          btn.textContent = '\u2600\uFE0F';
        } else {
          body.classList.remove('light');
          btn.textContent = '\uD83C\uDF19';
        }
        localStorage.setItem('theme', theme);
      }
      setTheme(localStorage.getItem('theme') || 'dark');
      btn.addEventListener('click', function() {
        setTheme(body.classList.contains('light') ? 'dark' : 'light');
      });
    })();
  </script>
</body>
</html>
