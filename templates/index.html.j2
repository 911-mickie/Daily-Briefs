<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ML Daily Brief — Archive</title>
  <link rel="stylesheet" href="./style.css">
</head>
<body>
  <div class="page">
    <header>
      <h1>🧠 ML Daily Brief</h1>
      <p class="date">Archive</p>
    </header>

    <main>
      {% if dates %}
      <ul class="archive-list">
        {% for d in dates %}
        <li>
          <a href="./{{ d }}.html">{{ d }}</a>
        </li>
        {% endfor %}
      </ul>
      {% else %}
      <p>No briefs yet. Check back tomorrow.</p>
      {% endif %}
    </main>

    <footer>
      <p>A daily ML/AI digest for practitioners preparing for interviews.</p>
    </footer>
  </div>
</body>
</html>
