<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ML Daily Brief — {{ date }}</title>
  <style>
    /* Reset */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    /* Header */
    .header {
      background: linear-gradient(135deg, #1a3028 0%, #243d32 100%);
      background-image: linear-gradient(135deg, #1a3028 0%, #243d32 100%);
      border-radius: 12px 12px 0 0;
      padding: 28px 32px 24px;
      border-bottom: 3px solid #4a9a6a;
    }

    .header h1 {
      font-size: 22px;
      font-weight: 700;
      color: #e0f0e4;
      letter-spacing: -0.02em;
      margin-bottom: 4px;
    }

    .header .meta {
      font-size: 11px;
      color: #8aba96;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 500;
    }

    /* Body */
    .body {
      background-color: #f8faf8;
      background-image: linear-gradient(#f8faf8, #f8faf8);
      padding: 28px 32px 32px;
    }

    /* Content typography */
    .brief-content {
      font-size: 14px;
      line-height: 1.8;
      color: #1e2e24;
    }

    .brief-content p {
      margin-bottom: 12px;
    }

    .brief-content p:empty {
      display: none;
    }

    .brief-content b {
      font-weight: 650;
      color: #0e1a12;
    }

    .brief-content i {
      color: #5a7a62;
      font-style: italic;
    }

    .brief-content a {
      color: #2d7a4a;
      text-decoration: none;
      border-bottom: 1px solid rgba(45, 122, 74, 0.3);
    }

    /* Section header badges */
    .section-header {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #3d8a5a;
      background-color: rgba(61, 138, 90, 0.08);
      background-image: linear-gradient(rgba(61, 138, 90, 0.08), rgba(61, 138, 90, 0.08));
      border: 1px solid rgba(61, 138, 90, 0.22);
      border-radius: 4px;
      padding: 3px 9px;
      margin: 18px 0 12px;
    }

    /* News cards */
    .news-card {
      background-color: #eef3ee;
      background-image: linear-gradient(#eef3ee, #eef3ee);
      border: 1px solid #c8d8ca;
      border-left: 3px solid #4a9a6a;
      border-radius: 6px;
      padding: 16px 20px;
      margin-bottom: 12px;
    }

    .news-card p {
      margin-bottom: 8px;
    }

    .news-card p:last-child {
      margin-bottom: 0;
    }

    /* Q&A sub-cards */
    .qa-card {
      background-color: #f8faf8;
      background-image: linear-gradient(#f8faf8, #f8faf8);
      border: 1px solid #c8d8ca;
      border-radius: 6px;
      padding: 12px 16px;
      margin-bottom: 8px;
    }

    .qa-card:last-child {
      margin-bottom: 0;
    }

    .qa-question {
      color: #0e1a12;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .qa-answer {
      color: #5a7a62;
      font-style: italic;
      margin-bottom: 0;
    }

    /* Dividers */
    .brief-content hr.divider {
      border: none;
      border-top: 1px solid #c8d8ca;
      margin: 16px 0;
    }

    /* Footer */
    .footer {
      background-color: #e2ebe4;
      background-image: linear-gradient(#e2ebe4, #e2ebe4);
      border-top: 1px solid #c8d8ca;
      border-radius: 0 0 12px 12px;
      padding: 16px 32px;
      text-align: center;
      font-size: 11px;
      color: #7a9a80;
      letter-spacing: 0.02em;
    }

    .footer a {
      color: #3d8a5a;
      text-decoration: underline;
    }

    @media (max-width: 600px) {
      .header { border-radius: 0; padding: 20px 20px 16px; }
      .body { padding: 20px 20px 24px; }
      .footer { border-radius: 0; padding: 12px 20px; }
      .news-card { padding: 12px 16px; }
    }
  </style>
</head>
<body style="margin: 0; padding: 0; background-color: #e8ede8;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #e8ede8; background-image: linear-gradient(#e8ede8, #e8ede8);">
    <tr>
      <td align="center" style="padding: 24px 12px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #1e2e24;">
        <div style="max-width: 640px; margin: 0 auto; border: 1px solid #c8d8ca; border-radius: 12px; overflow: hidden;">
          <div class="header">
            <h1>🧠 ML Daily Brief</h1>
            <div class="meta">{{ date }}</div>
          </div>

          <div class="body">
            <div class="brief-content">
              {{ content | safe }}
            </div>
          </div>

          <div class="footer">
            {% if base_url %}
            <p>Read in browser · <a href="{{ base_url }}/{{ date }}.html">View on GitHub Pages</a> · <a href="{{ base_url }}/index.html">All Briefs</a></p>
            {% else %}
            <p>Generated by Daily Briefs</p>
            {% endif %}
          </div>
        </div>
      </td>
    </tr>
  </table>
</body>
</html>
