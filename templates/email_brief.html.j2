<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ML Daily Brief — {{ date }}</title>
  <style>
    /* Reset */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    /* Header */
    .header {
      background: linear-gradient(135deg, #060d1f 0%, #0d1e3d 100%);
      background-image: linear-gradient(135deg, #060d1f 0%, #0d1e3d 100%);
      border-radius: 12px 12px 0 0;
      padding: 28px 32px 24px;
      border-bottom: 3px solid #0ea5e9;
    }

    .header h1 {
      font-size: 22px;
      font-weight: 700;
      color: #f1f5f9;
      letter-spacing: -0.02em;
      margin-bottom: 4px;
    }

    .header .meta {
      font-size: 11px;
      color: #4d7fa8;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 500;
    }

    /* Body */
    .body {
      background-color: #0a1628;
      background-image: linear-gradient(#0a1628, #0a1628);
      padding: 28px 32px 32px;
    }

    /* Content typography */
    .brief-content {
      font-size: 14px;
      line-height: 1.8;
      color: #94a3b8;
    }

    .brief-content p {
      margin-bottom: 12px;
    }

    .brief-content p:empty {
      display: none;
    }

    .brief-content b {
      font-weight: 650;
      color: #e2e8f0;
    }

    .brief-content i {
      color: #64748b;
      font-style: italic;
    }

    .brief-content a {
      color: #38bdf8;
      text-decoration: none;
      border-bottom: 1px solid rgba(56, 189, 248, 0.3);
    }

    /* Section header badges */
    .section-header {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #0ea5e9;
      background-color: rgba(14, 165, 233, 0.08);
      background-image: linear-gradient(rgba(14, 165, 233, 0.08), rgba(14, 165, 233, 0.08));
      border: 1px solid rgba(14, 165, 233, 0.22);
      border-radius: 4px;
      padding: 3px 9px;
      margin: 18px 0 12px;
    }

    /* News cards */
    .news-card {
      background-color: #0f1d32;
      background-image: linear-gradient(#0f1d32, #0f1d32);
      border: 1px solid #1e2d4a;
      border-left: 3px solid #0ea5e9;
      border-radius: 6px;
      padding: 16px 20px;
      margin-bottom: 12px;
    }

    .news-card p {
      margin-bottom: 8px;
    }

    .news-card p:last-child {
      margin-bottom: 0;
    }

    /* Q&A sub-cards */
    .qa-card {
      background-color: #0a1628;
      background-image: linear-gradient(#0a1628, #0a1628);
      border: 1px solid #1e2d4a;
      border-radius: 6px;
      padding: 12px 16px;
      margin-bottom: 8px;
    }

    .qa-card:last-child {
      margin-bottom: 0;
    }

    .qa-question {
      color: #e2e8f0;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .qa-answer {
      color: #64748b;
      font-style: italic;
      margin-bottom: 0;
    }

    /* Dividers */
    .brief-content hr.divider {
      border: none;
      border-top: 1px solid #1e2d4a;
      margin: 16px 0;
    }

    /* Footer */
    .footer {
      background-color: #060d1f;
      background-image: linear-gradient(#060d1f, #060d1f);
      border-top: 1px solid #1e2d4a;
      border-radius: 0 0 12px 12px;
      padding: 16px 32px;
      text-align: center;
      font-size: 11px;
      color: #2d4a6e;
      letter-spacing: 0.02em;
    }

    .footer a {
      color: #4d7fa8;
      text-decoration: underline;
    }

    @media (max-width: 600px) {
      .header { border-radius: 0; padding: 20px 20px 16px; }
      .body { padding: 20px 20px 24px; }
      .footer { border-radius: 0; padding: 12px 20px; }
      .news-card { padding: 12px 16px; }
    }
  </style>
</head>
<body style="margin: 0; padding: 0; background-color: #050b18;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #050b18; background-image: linear-gradient(#050b18, #050b18);">
    <tr>
      <td align="center" style="padding: 24px 12px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #94a3b8;">
        <div style="max-width: 640px; margin: 0 auto; border: 1px solid #1e2d4a; border-radius: 12px; overflow: hidden;">
          <div class="header">
            <h1>🧠 ML Daily Brief</h1>
            <div class="meta">{{ date }}</div>
          </div>

          <div class="body">
            <div class="brief-content">
              {{ content | safe }}
            </div>
          </div>

          <div class="footer">
            {% if base_url %}
            <p>Read in browser · <a href="{{ base_url }}/{{ date }}.html">View on GitHub Pages</a> · <a href="{{ base_url }}/index.html">All Briefs</a></p>
            {% else %}
            <p>Generated by Daily Briefs</p>
            {% endif %}
          </div>
        </div>
      </td>
    </tr>
  </table>
</body>
</html>
